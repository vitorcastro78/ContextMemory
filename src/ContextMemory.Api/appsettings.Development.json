{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "ContextMemory": "Debug",
      "ContextMemory.Core.Profile.ProfileLearner": "Information"
    }
  },
  "ContextMemory": {
    "DataPath": "../../data",
    "MasterKey": "cm_master_dev_key_change_me",
    "SummarizeAfterMessages": 50,
    "Apps": {
      "kyc-dev": {
        "ApiKey": "cm_live_dev_key_change_me",
        "SystemPrompt": "You are a KYC/AML compliance specialist. Respond accurately and professionally.",
        "DefaultLanguage": "pt-PT",
        "WikiPath": "../../wikis/kyc",
        "MaxHistoryMessages": 20,
        "WikiChunksTopK": 5,
        "SimilarityThreshold": 0.65
      }
    }
  }
}
