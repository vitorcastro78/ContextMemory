{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ContextMemory": {
    "DataPath": "./data",
    "WikiPath": "./wikis",
    "OllamaEndpoint": "http://localhost:11434",
    "MaxHistoryMessages": 20,
    "MaxPayloadBytes": 1048576,
    "WikiChunksTopK": 5,
    "SimilarityThreshold": 0.65,
    "MaxChunkTokens": 512,
    "ChunkOverlapTokens": 50,
    "SummarizeAfterMessages": 50,
    "MasterKey": "cm_master_dev_key_change_me",
    "LmStudioEndpoint": "http://localhost:1234",
    "OpenAiEndpoint": "https://api.openai.com",
    "OpenAiApiKey": "",
    "AuditLogPath": "./data/audit",
    "EnableContentFilter": true,
    "EnableFeedback": true,
    "EnableMetrics": true,
    "AdminEnabled": true,
    "DefaultRateLimitRpm": 60,
    "DefaultRateLimitTpm": 100000,
    "Apps": {}
  },
  "ContextMemory:Embeddings": {
    "ModelPath": "../ContextMemory.Embeddings/models/model.onnx",
    "VocabPath": "../ContextMemory.Embeddings/models/vocab.txt",
    "MaxSequenceLength": 256,
    "Dimensions": 384
  }
}
