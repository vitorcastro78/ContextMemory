@page "/settings"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout MainLayout

<PageTitle>Settings - ContextMemory Admin</PageTitle>

<div class="card card-outline card-primary">
    <div class="card-header"><h3 class="card-title">Admin connection</h3></div>
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>API base URL</label>
                <InputText class="form-control" @bind-Value="_model.ApiBaseUrl" placeholder="http://localhost:5100" />
            </div>

            <div class="form-group">
                <label>Master key</label>
                <InputText class="form-control" type="password" @bind-Value="_model.MasterKey" />
            </div>

            @if (_message is not null)
            {
                <div class="alert alert-success">@_message</div>
            }
            @if (_error is not null)
            {
                <div class="alert alert-danger">@_error</div>
            }

            <button class="btn btn-primary" type="submit" disabled="@_saving">Save</button>
            <button class="btn btn-outline-secondary ml-2" type="button" @onclick="TestConnectionAsync" disabled="@_saving">Test connection</button>
            <button class="btn btn-outline-danger ml-2" type="button" @onclick="ClearAsync" disabled="@_saving">Clear</button>
        </EditForm>
    </div>
</div>

@code {
    [Inject] private AdminSession Session { get; set; } = default!;
    [Inject] private AdminApiClient Api { get; set; } = default!;

    private AdminSettings _model = new();
    private bool _saving;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await Session.InitializeAsync();
        _model = new AdminSettings
        {
            ApiBaseUrl = Session.Settings.ApiBaseUrl,
            MasterKey = Session.Settings.MasterKey
        };
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _message = null;
        _error = null;
        try
        {
            await Session.SaveAsync(_model);
            _message = "Settings saved.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task TestConnectionAsync()
    {
        _saving = true;
        _message = null;
        _error = null;
        try
        {
            await Session.SaveAsync(_model);
            var apps = await Api.GetAppsAsync();
            _message = $"Connected: {apps.Count} app(s).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ClearAsync()
    {
        _saving = true;
        _message = null;
        _error = null;
        try
        {
            await Session.ClearAsync();
            _model = new AdminSettings();
            _message = "Settings cleared.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
