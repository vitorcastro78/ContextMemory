@page "/apps/{AppId}/users"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout MainLayout

<PageTitle>Users - ContextMemory Admin</PageTitle>

@if (_loading)
{
    <div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Loading users...</div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_users.Count == 0)
{
    <div class="alert alert-info">No users found.</div>
}
else
{
    <div class="card card-outline card-primary">
        <div class="card-header">
            <h3 class="card-title">Users for @AppId</h3>
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-hover text-nowrap">
                <thead>
                    <tr>
                        <th>UserId</th>
                        <th>Facts</th>
                        <th>Session context</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _users)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>@user.FactCount</td>
                            <td>@(user.HasSessionContext ? "Yes" : "No")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-secondary" href="/apps/@AppId/users/@user.UserId">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string AppId { get; set; } = string.Empty;
    [Inject] private AdminApiClient Api { get; set; } = default!;
    [Inject] private AdminSession Session { get; set; } = default!;

    private IReadOnlyList<UserAdminSummaryDto> _users = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        if (!Session.IsConfigured)
            await Session.InitializeAsync();

        if (!Session.IsConfigured)
        {
            _error = "Configure settings first.";
            _loading = false;
            return;
        }

        try
        {
            _users = await Api.GetUsersAsync(AppId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
