@inherits LayoutComponentBase

<div class="wrapper">
    <nav class="main-header navbar navbar-expand navbar-white navbar-light border-bottom">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button" @onclick:preventDefault>
                    <i class="fas fa-bars"></i>
                </a>
            </li>
            <li class="nav-item d-none d-sm-inline-block">
                <NavLink class="nav-link" href="/">Applications</NavLink>
            </li>
        </ul>
        <ul class="navbar-nav ms-auto">
            <li class="nav-item">
                <NavLink class="nav-link" href="/settings"><i class="fas fa-cog"></i> Settings</NavLink>
            </li>
        </ul>
    </nav>

    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a href="/" class="brand-link text-center">
            <span class="brand-text font-weight-light">ContextMemory Admin</span>
        </a>
        <div class="sidebar">
            <nav class="mt-2">
                <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <i class="nav-icon fas fa-th"></i>
                            <p>Applications</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/apps/new">
                            <i class="nav-icon fas fa-plus-circle"></i>
                            <p>Nova aplicação</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/companies/dashboard">
                            <i class="nav-icon fas fa-chart-pie"></i>
                            <p>Brain Dashboard</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/companies">
                            <i class="nav-icon fas fa-brain"></i>
                            <p>Empresas</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/chat">
                            <i class="nav-icon fas fa-comments"></i>
                            <p>Chat lab</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/settings">
                            <i class="nav-icon fas fa-key"></i>
                            <p>Connection</p>
                        </NavLink>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>

    <div class="content-wrapper">
        <section class="content pt-3">
            <div class="container-fluid">
                @if (!Session.IsConfigured)
                {
                    <div class="alert alert-warning">
                        Configure API URL and master key in <NavLink href="/settings">Settings</NavLink>.
                    </div>
                }
                @Body
            </div>
        </section>
    </div>

    <footer class="main-footer">
        <strong>ContextMemory</strong> Admin Console
    </footer>
</div>

@code {
    [Inject] private AdminSession Session { get; set; } = default!;

    private bool _sessionLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionLoaded)
            return;

        _sessionLoaded = true;
        await Session.InitializeAsync();
        StateHasChanged();
    }
}
