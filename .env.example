# All settings can also live in src/ContextMemory.Api/appsettings.json.
# Env vars override appsettings when both are set.
# ASP.NET Core uses double-underscore for nested configuration.
#
# Local evaluation (no Docker):
#   1. Install Ollama locally and run: ollama pull llama3.2
#   2. Run: ./scripts/download-embedding-model.ps1  (optional, for RAG)
#   3. cd src/ContextMemory.Api && dotnet run
#   4. API: http://localhost:5100  |  Ollama: http://localhost:11434
#
# Persistence: JSON files under ContextMemory__DataPath (./data) when PersistenceProvider=File.
# Use Postgres for conversation memory, profiles, feedback, audit, app config (see README).

# PostgreSQL (when ContextMemory__PersistenceProvider=Postgres)
ConnectionStrings__ContextMemory=Host=localhost;Port=5432;Database=contextmemory;Username=postgres;Password=postgres
ContextMemory__PersistenceProvider=Postgres

ContextMemory__MasterKey=cm_master_dev_key_change_me
ContextMemory__OllamaEndpoint=http://localhost:11434
ContextMemory__LmStudioEndpoint=http://localhost:1234
ContextMemory__OpenAiEndpoint=https://api.openai.com
ContextMemory__OpenAiApiKey=
ContextMemory__DataPath=./data
ContextMemory__WikiPath=./wikis
ContextMemory__MaxHistoryMessages=20
ContextMemory__WikiChunksTopK=5
ContextMemory__SimilarityThreshold=0.65
ContextMemory__SummarizeAfterMessages=50
ContextMemory__EnableContentFilter=true
ContextMemory__EnableFeedback=true
ContextMemory__EnableMetrics=true
ContextMemory__AdminEnabled=true
ContextMemory__DefaultRateLimitRpm=60
ContextMemory__DefaultRateLimitTpm=100000
ContextMemory__ActiveUserWindowMinutes=15
ContextMemory__AuditLogPath=./data/audit

# Embeddings (ONNX model — run scripts/download-embedding-model.ps1)
ContextMemory__Embeddings__ModelPath=../ContextMemory.Embeddings/models/model.onnx
ContextMemory__Embeddings__VocabPath=../ContextMemory.Embeddings/models/vocab.txt
